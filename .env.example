# Alpaca API (https://alpaca.markets — sign up free, get keys from dashboard)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Bybit API (https://www.bybit.com/app/user/api-management — mainnet,
# https://testnet.bybit.com — testnet. Testnet keys are SEPARATE from mainnet keys.)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
# true = api-testnet.bybit.com, false = api.bybit.com
BYBIT_TESTNET=true
# Optional: receive window in ms for HMAC-signed requests (default 5000)
BYBIT_RECV_WINDOW=5000

# FRED API (https://fred.stlouisfed.org/docs/api/api_key.html — free)
FRED_API_KEY=your_fred_key_here

# Groq API (https://console.groq.com — free tier, Llama 4 Scout)
GROQ_API_KEY=your_groq_key_here

# Trading mode: paper or live
TRADING_MODE=paper
